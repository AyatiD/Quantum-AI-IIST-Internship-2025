      "source": [
        "!pip install cirq\n",
        "import cirq\n",
        "\n",
        "# Define qubits\n",
        "q0, q1 = cirq.LineQubit.range(2)\n",
        "\n",
        "# Create a circuit\n",
        "circuit = cirq.Circuit(\n",
        "    cirq.H(q0),           # Hadamard gate\n",
        "    cirq.CNOT(q0, q1)     # Entanglement\n",
        ")\n",
        "\n",
        "print(circuit)"
      ]
